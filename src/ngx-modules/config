# Nginx 模块编译配置脚本
# 用于 --add-module 或 --add-dynamic-module

ngx_addon_name=ngx_http_hello_module

# 添加模块源文件
NGX_ADDON_SRCS="$NGX_ADDON_SRCS $ngx_addon_dir/src/ngx_http_hello_module.c"

# 添加头文件路径 (如果有)
# NGX_ADDON_DEPS="$NGX_ADDON_DEPS $ngx_addon_dir/include/ngx_http_hello.h"

# 如果是 HTTP 模块
if test -n "$ngx_module_link"; then
    ngx_module_type=HTTP_FILTER
    ngx_module_name=ngx_http_hello_module
    ngx_module_srcs="$ngx_addon_dir/src/ngx_http_hello_module.c"
    . auto/module
else
    HTTP_MODULES="$HTTP_MODULES ngx_http_hello_module"
fi