#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Dev CLI - 统一开发命令入口 (Windows Only)

用法:
  dev build     - 构建
  dev test      - 测试
  dev start     - 启动服务
  dev stop      - 停止服务
"""

import io
import os
import subprocess
import sys
from pathlib import Path

# 修复 Windows 终端中文编码
sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding='utf-8', errors='replace')
sys.stderr = io.TextIOWrapper(sys.stderr.buffer, encoding='utf-8', errors='replace')

# ============================================================
# 绝对路径
# ============================================================

TOOLS_DIR = Path(__file__).parent.parent.resolve()
PROJECT_ROOT = TOOLS_DIR.parent.resolve()
CONFIG_PATH = TOOLS_DIR / "config" / "dev.yaml"

# Windows SSH 路径
SSH_PATH = r"D:\Program Files (x86)\Git\usr\bin\ssh.exe"

# ============================================================
# 工具函数
# ============================================================

def log_i(msg: str): print(f"[INFO] {msg}")
def log_s(msg: str): print(f"[OK] {msg}")
def log_e(msg: str): print(f"[ERROR] {msg}", file=sys.stderr)

def parse_yaml(path: Path) -> dict:
    """简单 YAML 解析"""
    result = {}
    section = None
    sub = None

    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.rstrip()
            if not line or line.startswith('#'):
                continue

            indent = len(line) - len(line.lstrip())
            line = line.strip()

            if ':' in line:
                key, _, val = line.partition(':')
                key = key.strip()
                val = val.strip()

                if indent == 0:
                    section = key
                    sub = None
                    result[key] = val if val else {}
                elif indent == 2 and section:
                    if val:
                        if val.startswith('"') and val.endswith('"'):
                            val = val[1:-1]
                        elif val.startswith("'") and val.endswith("'"):
                            val = val[1:-1]
                        result[section][key] = val
                    else:
                        result[section][key] = {}
                        sub = key
                elif indent == 4 and sub and section:
                    if val:
                        if val.startswith('"') and val.endswith('"'):
                            val = val[1:-1]
                        elif val.startswith("'") and val.endswith("'"):
                            val = val[1:-1]
                        result[section][sub][key] = val

    return result

def load_config() -> dict:
    if not CONFIG_PATH.exists():
        log_e(f"配置文件不存在: {CONFIG_PATH}")
        sys.exit(1)
    try:
        return parse_yaml(CONFIG_PATH)
    except Exception as e:
        log_e(f"配置解析失败: {e}")
        sys.exit(1)

def exec_remote(config: dict, cmd: str) -> int:
    """远程执行命令"""
    r = config.get('remote', {})
    host = r.get('host', '')
    port = r.get('port', 22)
    user = r.get('user', '')
    workdir = r.get('workdir', '')

    if not all([host, user, workdir]):
        log_e("配置缺少: host, user, workdir")
        return 1

    log_i(f"执行: {cmd}")

    # 构造 SSH 命令
    ssh_cmd = [
        SSH_PATH,
        '-p', str(port),
        f"{user}@{host}",
        f"cd {workdir} && {cmd}"
    ]

    # 执行
    try:
        result = subprocess.run(ssh_cmd)
        if result.returncode == 0:
            log_s("成功")
        else:
            log_e(f"失败 (code: {result.returncode})")
        return result.returncode
    except FileNotFoundError:
        log_e(f"SSH 未找到: {SSH_PATH}")
        return 1
    except Exception as e:
        log_e(f"异常: {e}")
        return 1

# ============================================================
# 命令
# ============================================================

COMMANDS = {
    'build': 'bash tools/scripts/build.sh',
    'test': 'bash tools/scripts/test.sh',
    'start': 'bash tools/scripts/start.sh',
    'stop': 'bash tools/scripts/stop.sh',
}

def main():
    if len(sys.argv) < 2:
        print("用法: dev [build|test|start|stop]")
        sys.exit(0)

    cmd = sys.argv[1]
    if cmd not in COMMANDS:
        log_e(f"未知命令: {cmd}")
        sys.exit(1)

    config = load_config()
    sys.exit(exec_remote(config, COMMANDS[cmd]))

if __name__ == '__main__':
    main()