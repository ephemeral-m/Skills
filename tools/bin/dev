#!/usr/bin/env python3
"""
Dev CLI - 统一开发命令入口
零Token消耗的命令行工具，处理编译、测试、部署等工程任务

用法:
  dev build [module]     - 编译指定模块或全部
  dev test [module]      - 测试指定模块或全部
  dev clean              - 清理构建产物
  dev verify [module]    - 完整验证流程（build + test）
  dev sync [remote]      - 同步代码到远程服务器
  dev status             - 查看项目状态
  dev help               - 显示帮助
"""

import argparse
import json
import os
import re
import subprocess
import sys
import time
import yaml
from datetime import datetime
from pathlib import Path
from typing import Optional, Dict, Any, List

# 路径配置
TOOLS_DIR = Path(__file__).parent.parent.resolve()
PROJECT_ROOT = TOOLS_DIR.parent.resolve()
SCRIPTS_DIR = TOOLS_DIR / "scripts"
CONFIG_DIR = TOOLS_DIR / "config"
RESULTS_DIR = TOOLS_DIR / "results"
STATE_DIR = TOOLS_DIR / "state"
FIXERS_DIR = TOOLS_DIR / "fixers"
CONFIG_PATH = CONFIG_DIR / "dev.yaml"

# 颜色输出
class Colors:
    RED = '\033[0;31m'
    GREEN = '\033[0;32m'
    YELLOW = '\033[1;33m'
    BLUE = '\033[0;34m'
    NC = '\033[0m'

def log_info(msg: str):
    print(f"{Colors.BLUE}[INFO]{Colors.NC} {msg}")

def log_success(msg: str):
    print(f"{Colors.GREEN}[SUCCESS]{Colors.NC} {msg}")

def log_warn(msg: str):
    print(f"{Colors.YELLOW}[WARN]{Colors.NC} {msg}")

def log_error(msg: str):
    print(f"{Colors.RED}[ERROR]{Colors.NC} {msg}", file=sys.stderr)

def show_suggestion(fix_type: str, module: str = ""):
    print()
    print(f"{Colors.YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━{Colors.NC}")
    print(f"{Colors.YELLOW}建议执行: /fix-{fix_type} {module}{Colors.NC}")
    print(f"{Colors.YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━{Colors.NC}")


class DevCLI:
    def __init__(self, config_path: Path = CONFIG_PATH):
        self.config = self._load_config(config_path)
        self.project_root = PROJECT_ROOT
        self.tools_dir = TOOLS_DIR

    def _load_config(self, config_path: Path) -> Dict[str, Any]:
        if not config_path.exists():
            log_error(f"配置文件 {config_path} 不存在")
            sys.exit(1)
        with open(config_path, 'r', encoding='utf-8') as f:
            config = yaml.safe_load(f)
        return self._substitute_env_vars(config)

    def _substitute_env_vars(self, obj: Any) -> Any:
        if isinstance(obj, str):
            pattern = r'\$\{([^}:]+):-([^}]*)\}'
            def replacer(match):
                return os.environ.get(match.group(1), match.group(2))
            return re.sub(pattern, replacer, obj)
        elif isinstance(obj, dict):
            return {k: self._substitute_env_vars(v) for k, v in obj.items()}
        elif isinstance(obj, list):
            return [self._substitute_env_vars(item) for item in obj]
        return obj

    def _get_remote_config(self, remote_name: str) -> Dict[str, Any]:
        remotes = self.config.get('remotes', {})
        if remote_name in remotes:
            return remotes[remote_name]
        if remote_name == 'default':
            return self.config.get('remote', {})
        return {}

    def sync_to_remote(self, remote_name: str = "default") -> bool:
        remote_config = self._get_remote_config(remote_name)
        if not remote_config:
            log_error(f"远程配置 '{remote_name}' 不存在")
            return False

        host = remote_config['host']
        port = remote_config.get('port', 22)
        user = remote_config['user']
        workdir = remote_config['workdir']

        log_info(f"同步代码到 {user}@{host}:{workdir}")

        exclude_patterns = self.config.get('sync', {}).get('exclude', [
            ".git", ".idea", ".claude", ".vscode",
            "node_modules", "__pycache__", "build", "*.o", "*.a"
        ])

        rsync_cmd = [
            "rsync", "-avz", "--delete",
            *[f"--exclude={p}" for p in exclude_patterns],
            "-e", f"ssh -p {port} -o StrictHostKeyChecking=no",
            f"{self.project_root}/",
            f"{user}@{host}:{workdir}/"
        ]

        result = subprocess.run(rsync_cmd, capture_output=True, text=True)
        if result.returncode != 0:
            log_error(f"同步失败: {result.stderr}")
            return False

        log_success("同步成功")
        return True

    def execute_remote(self, command: str, remote_name: str = "default") -> Dict[str, Any]:
        remote_config = self._get_remote_config(remote_name)
        if not remote_config:
            return {"success": False, "error": f"远程配置 '{remote_name}' 不存在"}

        host = remote_config['host']
        port = remote_config.get('port', 22)
        user = remote_config['user']
        workdir = remote_config['workdir']

        log_info(f"远程执行 [{remote_name}]: {command}")

        ssh_cmd = [
            "ssh", "-p", str(port), "-o", "StrictHostKeyChecking=no",
            f"{user}@{host}",
            f"cd {workdir} && {command}"
        ]

        start_time = time.time()
        result = subprocess.run(ssh_cmd, capture_output=True, text=True)
        duration = time.time() - start_time

        return {
            "success": result.returncode == 0,
            "returncode": result.returncode,
            "stdout": result.stdout,
            "stderr": result.stderr,
            "duration": duration,
            "timestamp": datetime.now().isoformat()
        }

    def execute_local(self, script_name: str, args: str = "") -> Dict[str, Any]:
        script_path = SCRIPTS_DIR / f"{script_name}.sh"
        if not script_path.exists():
            log_error(f"脚本不存在: {script_path}")
            return {"success": False, "returncode": 1, "stdout": "", "stderr": f"脚本不存在: {script_path}", "duration": 0, "timestamp": datetime.now().isoformat()}

        command = f"bash {script_path} {args}".strip()
        log_info(f"执行: {script_name}.sh {args}".strip())

        start_time = time.time()
        result = subprocess.run(command, shell=True, capture_output=True, text=True, cwd=self.project_root)
        duration = time.time() - start_time

        return {
            "success": result.returncode == 0,
            "returncode": result.returncode,
            "stdout": result.stdout,
            "stderr": result.stderr,
            "duration": duration,
            "timestamp": datetime.now().isoformat()
        }

    def classify_error(self, output: str) -> str:
        if re.search(r"error:|fatal error:|undefined reference|cannot find|was not declared", output, re.IGNORECASE):
            return "compile"
        if re.search(r"\[  FAILED  \]|Assertion|expected|actual|FAIL:", output, re.IGNORECASE):
            return "test"
        if re.search(r"segmentation fault|SIGSEGV|panic:|exception", output, re.IGNORECASE):
            return "runtime"
        return "unknown"

    def parse_errors(self, output: str, error_type: str) -> List[Dict[str, Any]]:
        errors = []
        patterns = self.config.get('error_patterns', {}).get(error_type, [])
        for pattern_config in patterns:
            pattern = pattern_config['pattern']
            error_category = pattern_config['type']
            fix_hint = pattern_config.get('fix_hint', '')
            for match in re.findall(pattern, output, re.MULTILINE):
                errors.append({
                    "type": error_category,
                    "match": match if isinstance(match, str) else list(match),
                    "hint": fix_hint
                })
        return errors

    def save_result(self, command_type: str, module: str, result: Dict[str, Any], errors: List[Dict[str, Any]]):
        RESULTS_DIR.mkdir(parents=True, exist_ok=True)
        result_file = RESULTS_DIR / f"{command_type}-{module or 'all'}.json"

        error_type = "none" if result["success"] else self.classify_error(result["stderr"] + "\n" + result["stdout"])

        output_data = {
            "command": command_type,
            "module": module or "all",
            "exit_code": result["returncode"],
            "timestamp": result["timestamp"],
            "duration": result["duration"],
            "error_type": error_type,
            "success": result["success"],
            "errors": errors,
            "output": result["stdout"],
            "error_output": result["stderr"]
        }

        with open(result_file, 'w', encoding='utf-8') as f:
            json.dump(output_data, f, indent=2, ensure_ascii=False)

        log_info(f"结果已保存: tools/results/{result_file.name}")

    def cmd_build(self, module: Optional[str] = None, local: bool = False) -> int:
        log_info(f"开始构建...")

        # 检查是否远程执行
        if not local:
            remote_name = self.config.get('defaults', {}).get('build', {}).get('remote', 'default')
            if remote_name:
                if not self.sync_to_remote(remote_name):
                    return 1
                # 远程执行 make
                result = self.execute_remote("make -j4", remote_name)
            else:
                result = self.execute_local("build")
        else:
            result = self.execute_local("build")

        if result["stdout"]:
            print(result["stdout"])
        if result["stderr"]:
            print(result["stderr"], file=sys.stderr)

        output = result["stdout"] + "\n" + result["stderr"]
        error_type = self.classify_error(output) if not result["success"] else "none"
        errors = self.parse_errors(output, error_type) if error_type != "none" else []

        self.save_result("build", module or "", result, errors)

        if result["success"]:
            log_success(f"构建成功 (耗时: {result['duration']:.2f}s)")
            return 0
        else:
            log_error(f"构建失败 (exit code: {result['returncode']})")
            if errors:
                print(f"\n检测到 {len(errors)} 个错误:")
                for err in errors[:5]:
                    print(f"  - [{err['type']}] {err['match']}")
            show_suggestion(error_type, module or "")
            return result['returncode']

    def cmd_test(self, module: Optional[str] = None, local: bool = False) -> int:
        log_info(f"开始测试...")

        if not local:
            remote_name = self.config.get('defaults', {}).get('test', {}).get('remote', 'default')
            if remote_name:
                result = self.execute_remote("make test", remote_name)
            else:
                result = self.execute_local("test")
        else:
            result = self.execute_local("test")

        if result["stdout"]:
            print(result["stdout"])
        if result["stderr"]:
            print(result["stderr"], file=sys.stderr)

        output = result["stdout"] + "\n" + result["stderr"]
        error_type = self.classify_error(output) if not result["success"] else "none"
        errors = self.parse_errors(output, error_type) if error_type != "none" else []

        self.save_result("test", module or "", result, errors)

        if result["success"]:
            log_success(f"测试通过 (耗时: {result['duration']:.2f}s)")
            return 0
        else:
            log_error(f"测试失败 (exit code: {result['returncode']})")
            show_suggestion("test", module or "")
            return result['returncode']

    def cmd_clean(self) -> int:
        result = self.execute_local("clean")
        if result["stdout"]:
            print(result["stdout"])
        return result["returncode"]

    def cmd_verify(self, module: Optional[str] = None) -> int:
        log_info("执行完整验证流程...")
        build_result = self.cmd_build(module)
        if build_result != 0:
            log_error("验证失败：构建未通过")
            return build_result
        test_result = self.cmd_test(module)
        if test_result != 0:
            log_error("验证失败：测试未通过")
            return test_result
        log_success("验证通过")
        return 0

    def cmd_sync(self, remote: str = "default") -> int:
        return 0 if self.sync_to_remote(remote) else 1

    def cmd_status(self) -> int:
        project_name = self.config.get('project', {}).get('name', 'project')
        print(f"{Colors.BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━{Colors.NC}")
        print(f"{Colors.BLUE}项目: {project_name}{Colors.NC}")
        print(f"{Colors.BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━{Colors.NC}")

        print("\n最近构建结果:")
        if RESULTS_DIR.exists():
            for result_file in sorted(RESULTS_DIR.glob("build-*.json"), key=lambda x: x.stat().st_mtime, reverse=True)[:5]:
                with open(result_file) as f:
                    data = json.load(f)
                status = f"{Colors.GREEN}✓{Colors.NC}" if data.get("success") else f"{Colors.RED}✗{Colors.NC}"
                print(f"  {status} {result_file.stem}")

        print("\n最近测试结果:")
        if RESULTS_DIR.exists():
            for result_file in sorted(RESULTS_DIR.glob("test-*.json"), key=lambda x: x.stat().st_mtime, reverse=True)[:5]:
                with open(result_file) as f:
                    data = json.load(f)
                status = f"{Colors.GREEN}✓{Colors.NC}" if data.get("success") else f"{Colors.RED}✗{Colors.NC}"
                print(f"  {status} {result_file.stem}")

        return 0


def main():
    parser = argparse.ArgumentParser(
        description='Dev CLI - 统一开发命令入口',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  dev build          # 构建
  dev test           # 测试
  dev verify         # 完整验证
  dev status         # 查看状态
        """
    )

    parser.add_argument('command', nargs='?', default='help', help='命令 (build/test/clean/verify/sync/status/help)')
    parser.add_argument('module', nargs='?', default=None, help='目标模块')
    parser.add_argument('--local', action='store_true', help='本地执行')

    args = parser.parse_args()
    cli = DevCLI()

    command_map = {
        'build': lambda: cli.cmd_build(args.module, args.local),
        'test': lambda: cli.cmd_test(args.module, args.local),
        'clean': cli.cmd_clean,
        'verify': lambda: cli.cmd_verify(args.module),
        'sync': lambda: cli.cmd_sync(),
        'status': cli.cmd_status,
        'help': lambda: parser.print_help()
    }

    if args.command in command_map:
        sys.exit(command_map[args.command]())
    else:
        log_error(f"未知命令: {args.command}")
        parser.print_help()
        sys.exit(1)


if __name__ == '__main__':
    main()